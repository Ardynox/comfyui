# OS / Editor
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# Claude Code session local state
.claude/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Secrets (API keys for GPT image / other services)
.env
.env.*
!.env.example
secrets/
scripts/.secrets

# Logs
*.log

# Blender temp / autosave
*.blend1
*.blend2
*.blend@
*.blend~

# Photoshop temp
~$*.psd
*.psdtmp

# Generic temp / cache
*.tmp
*.bak
*.swp
*.swo
cache/
temp/
tmp/

# Godot cache
.godot/
godot_project/.godot/

# Generated pipeline intermediates
02_blender/renders/beauty/*
!02_blender/renders/beauty/.gitkeep
02_blender/renders/depth/*
!02_blender/renders/depth/.gitkeep
!02_blender/renders/depth/README.md
# Track depth PNGs (small, ~5 MB total) so CI can consume them as input.
# The README in the same dir guards against non-canonical files landing here.
!02_blender/renders/depth/*.png
02_blender/renders/normal/*
!02_blender/renders/normal/.gitkeep
02_blender/renders/pose/*
!02_blender/renders/pose/.gitkeep
03_comfyui_input/*
!03_comfyui_input/.gitkeep
04_comfyui_output/raw/*
!04_comfyui_output/raw/.gitkeep
# Track canonical female base 5-view sheets so CI outfit workflow can use
# them as input. Drift versions (*_male.png) and other generated sheets stay
# ignored. Outfit outputs (female_ageN_outfit_*.png) also tracked so they
# survive across CI runs.
!04_comfyui_output/raw/female_age[0-8]_5views_gptimage.png
!04_comfyui_output/raw/female_age[0-8]_outfit_*.png
!04_comfyui_output/raw/male_normal_5views_gptimage.png
!04_comfyui_output/raw/male_normal_outfit_*.png
